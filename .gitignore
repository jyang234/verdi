# Build artifacts (CLAUDE.md: "derived state is disposable"). Note this is
# distinct from .verdi/.gitignore, which excludes only .verdi/data/ (the
# store's own working area, D1/D3) — this file is ordinary Go-module
# hygiene for the repo root.
/.build/
/verdi
# The e2e Playwright harness binary (playwright.config.ts runs it via `go
# run`, never a committed build) — spec/fail-loud ac-1.
/e2eharness
